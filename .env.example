# =============================================================================
# PropTech ML Inference Pipeline - Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed.
# DO NOT commit your actual .env file with real credentials.
# =============================================================================

# AWS Credentials (use 'test' for LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Ansible Configuration
ANSIBLE_SSH_USER=ubuntu
ANSIBLE_SSH_PRIVATE_KEY_FILE=~/.ssh/id_rsa

# Intake API
INTAKE_API_URL=http://localhost:8080/upload

# LocalStack Configuration
LOCALSTACK_URL=http://localhost:4566
LOCALSTACK_DOCKER_NAME=localstack-main

# AWS Resource Names
S3_BUCKET_NAME=proptech-image-uploads
SNS_TOPIC_NAME=proptech-notifications
LAMBDA_FUNCTION_NAME=QualityCheckLambda
STATE_MACHINE_NAME=proptech-image-pipeline

# Application Settings
DEBUG=1
UPLOAD_WORKERS=10
BLUR_THRESHOLD=100.0
PORT=8080
